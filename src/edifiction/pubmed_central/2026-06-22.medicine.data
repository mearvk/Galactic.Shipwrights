  <main class="usa-section padding-top-0" id="main-content">
    <h1 class="usa-sr-only">PubMed Central (PMC) Search Page</h1>

    <!-- Action toolbar: full width, above sidebar + results columns -->
    <div class="border-bottom border-base-lighter margin-bottom-2">
      <div class="grid-container margin-top-1 margin-bottom-1">
        <div class="grid-row grid-gap">
          <div class="desktop:grid-col-3"></div>
          <div class="desktop:grid-col-9">


<div class="grid-container padding-left-0 padding-right-0">
  <!-- Top row with action buttons and sorting -->
  <div class="grid-row flex-align-center">
    <!-- Left section: Action buttons -->
    <div class="grid-col-4 desktop:grid-col-5">
      <ul class="usa-button-group flex-row">
        <!-- Export/Save button - only shown when there are results -->
        
        
        <!-- Mobile-only buttons -->
        <li class="usa-button-group__item margin-right-1 desktop:display-none">
          <button
             class="usa-button usa-button--unstyled search-toolbar-mobile-icon-button pmc-sidenav__container__open display-flex flex-align-center" 
             aria-label="Open filters" 
             data-ga-category="filter" 
             data-ga-action="open" 
             data-ga-label="search_page_mobile_menu"
             type="button">
            <svg class="usa-icon" aria-hidden="true" focusable="false" role="img">
              <use xlink:href="/search/static/img/sprite.svg#filter_list"></use>
            </svg>
            <span aria-hidden="true"></span>
          </button>
        </li>
        
        <!-- Timeline button -->
        <li class="usa-button-group__item margin-right-1 desktop:display-none">
          <button
             class="usa-button usa-button--unstyled search-toolbar-mobile-icon-button expand-timeline-mobile display-flex flex-align-center" 
             aria-label="Open timeline" 
             data-ga-category="timeline" 
             data-ga-action="open" 
             data-ga-label="search_page_mobile_menu"
             type="button">
            <svg class="usa-icon" aria-hidden="true" focusable="false" role="img">
              <use xlink:href="/search/static/img/sprite.svg#assessment"></use>
            </svg>
            <span aria-hidden="true"></span>
          </button>
        </li>
      </ul>
    </div>

    <!-- Right section: Sort controls -->
    <div class="grid-col-6 desktop:grid-col-7 display-flex flex-justify-end">
      <div class="display-flex flex-align-center desktop:margin-right-2">
        <label for="search-sort" class="usa-sr-only">Sort by</label>
        <span class="padding-right-1 text-no-wrap flex-align-self-center desktop:display-inline display-none">Sort by:</span>
        
        
          <select id="search-sort" name="sort" class="usa-select margin-top-0 search-sort-select">
            
            <option value="relevance" 
                    data-ga-category="sort_option" 
                    data-ga-action="select" 
                    data-ga-label="relevance" 
                    selected>
              Relevance
            </option>
            
            <option value="date" 
                    data-ga-category="sort_option" 
                    data-ga-action="select" 
                    data-ga-label="date" 
                    >
              Most Recent
            </option>
            
            <option value="pubdate" 
                    data-ga-category="sort_option" 
                    data-ga-action="select" 
                    data-ga-label="pubdate" 
                    >
              Publication Date
            </option>
            
          </select>
          
        
        
      </div>
      <div class="display-none desktop:display-block">
        

<button type="button" class="display-flex usa-button usa-button--outline text-center flex-align-center margin-right-0 " aria-controls="display-options-modal" data-ga-category="save_share" data-ga-action="save" data-ga-label="open" aria-label="Display Options" data-open-modal>
  <svg class="usa-icon usa-button__icon--left" role="graphics-symbol" aria-hidden="true">
    <use xlink:href="/search/static/img/sprite.svg#settings"></use>
  </svg>
  <span class="display-none desktop:display-inline">Display Options</span>
</button>


  

<div class="usa-modal usa-modal-wrapper usa-prose maxw-tablet"
     id="display-options-modal"
     aria-labelledby="display-options-modal-heading"
     aria-describedby="display-options-modal-description">
  <div class="usa-modal__content">
    <div class="usa-modal__main margin-0">
      <h2 class="usa-modal__heading" id="display-options-modal-heading">Display options</h2>
      <p class="usa-sr-only" id="display-options-modal-description">
        Choose how results are displayed.
      </p>

      
      <form class="usa-form maxw-full" id="display-options-form" name="displayOptionsForm" method="get">

        
        <div class="grid-row grid-gap margin-bottom-3 flex-align-center">
          <div class="grid-col-12 tablet:grid-col-4">
            <label class="usa-label margin-top-0" for="display-format">Format</label>
          </div>
