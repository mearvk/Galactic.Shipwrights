      {
        "href": "https://images-assets.nasa.gov/image/KSC-20161202-PH_DNG01_0031/collection.json",
        "data": [
          {
            "center": "KSC",
            "date_created": "2016-12-02T00:00:00Z",
            "description": "Inside the Vehicle Assembly Building (VAB) at NASA’s Kennedy Space Center in Florida, a construction worker watches as the first half of the B-level work platforms, B south, for NASA’s Space Launch System (SLS) rocket is lowered into place in High Bay 3. Construction workers will secure the large bolts that hold the platform in place on the south wall. The B platforms are the ninth of 10 levels of work platforms that will surround and provide access to the SLS rocket and Orion spacecraft for Exploration Mission 1. The Ground Systems Development and Operations Program is overseeing upgrades and modifications to VAB High Bay 3, including installation of the new work platforms, to prepare for NASA’s Journey to Mars.",
            "keywords": [
              "GSDO",
              "VAB",
              "platforms",
              "SLS",
              "exploration",
              "EM-1",
              "Journey to Mars"
            ],
            "location": "VAB",
            "media_type": "image",
            "nasa_id": "KSC-20161202-PH_DNG01_0031",
            "photographer": "NASA/Dimitri Gerondidakis",
            "title": "Platform B South Installation"
          }
        ],
        "links": [
          {
            "href": "https://images-assets.nasa.gov/image/KSC-20161202-PH_DNG01_0031/KSC-20161202-PH_DNG01_0031~medium.jpg",
            "rel": "alternate",
            "render": "image",
            "width": 853,
