        "data": [
          {
            "center": "MSFC",
            "date_created": "2008-04-16T00:00:00Z",
            "description": "DOUG HUIE, RESEARCH TECHNICIAN AT THE UNIVERSITY OF ALABAMA IN HUNTSVILLE, CAFEFULLY SETS THE NANOSAIL-D SATELLITE ON A SPECIALLY CONSTRUCTED SURFACE DESIGNED FOR DEPLOYMENT TESTING. THE SPACECRAFT MEASURES 4 INCHES WIDE, 4 INCHES DEEP, AND 13 INCHES LONG, ROUGHLY THE SIZE OF A LOAF OF BREAD, AND WEIGHING ABOUT 9 POUNDS.",
            "keywords": [
              "NANOSAIL-D",
              "DOUG HUIE"
            ],
            "media_type": "image",
