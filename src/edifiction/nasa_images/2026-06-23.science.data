      {
        "href": "https://images-assets.nasa.gov/image/KSC-2012-1852/collection.json",
        "data": [
          {
            "center": "KSC",
            "date_created": "2012-02-17T00:00:00Z",
            "description": "Industrial Area Construction:  Located 5 miles south of Launch Complex 39, construction of the main buildings -- Operations and Checkout Building, Headquarters Building, and Central Instrumentation Facility – began in 1963.  In 1992, the Space Station Processing Facility was designed and constructed for the pre-launch processing of International Space Station hardware that was flown on the space shuttle.  Along with other facilities, the industrial area provides spacecraft assembly and checkout, crew training, computer and instrumentation equipment, hardware preflight testing and preparations, as well as administrative offices.      Poster designed by Kennedy Space Center Graphics Department/Greg Lee. Credit: NASA",
            "location": "Kennedy Space Center, FL",
            "media_type": "image",
            "nasa_id": "KSC-2012-1852",
            "title": "KSC-2012-1852"
          }
        ],
