            <div class="field field--name-body field--type-text-with-summary field--label-hidden field__item"><style>
  #banner {
    background-image: url("/media/stripes-swoosh.svg"), linear-gradient(90deg, rgba(0, 56, 102, 0.976628) 24%, rgba(0, 56, 102, 0.854779) 92%);
    background-repeat: no-repeat, no-repeat;
    background-size: 656px auto, cover;
    background-position: calc(50% + 40px) -45px, top left;
    padding-top: 1em;
    transition: background-position 0.25s ease, background-size 0.25s ease;
  }

  #america-250-banner {
    position: relative;
    width: 90px;
    overflow: hidden;
    margin: 1em auto 0 auto;
    height: 80px;
  }  

  #a250-celebrate-banner {
    width: 400px;
  }

  @media screen and (min-width: 768px) {
    #banner {
      background-size: 1200px auto, cover;
      background-position: -8px -80px, top left;
    }

    #america-250-banner {
      left: auto;
      width: unset;
      margin-left: 8px;
    }

    #a250-celebrate-banner {
      width: 400px;
    }
}

  @media screen and (min-width: 960px) {
    #banner {
      background-size: 1622px auto, cover;
      background-position: calc(50% + 210px) -110px, top left;
    }
  }
</style>
<div class="container">
  <div id="america-250-banner">
    <!-- <img id="a250-celebrate-banner" src="/media/america-250-celebrate.svg" width="435.43" height="80.43" alt="America 250 - Celebrating America's Birthday, 1776-2026" /> -->
    <svg id="a250-celebrate-banner" data-name="a250-celebrate" alt="America 250 - Celebrating America's Birthday, 1776-2026" viewBox="0 0 435.43 80.43">
      <title id="svgTitle">America 250 - Celebrating America's Birthday, 1776-2026</title>
      <style>
        .red {
          fill: #c32040;
        }

        .red, .white {
          stroke-width: 0px;
        }

        .white {
          fill: #fff;
        }

        #a250-celebrate {
          clip-path: rect(0 80px 70px 0);
        }

        #a250-celebrate > g:not(.stars) {
          display: none;
        }

        @media screen and (min-width: 768px) {
          #a250-celebrate {
            clip-path: unset;
          }

          #a250-celebrate > g:not(.stars) {
            display: block;
          }
        }
      </style>
      <use href="/media/america-250-celebrate.svg#a250-celebrate" viewBox="0 0 435.43 80.43" role="img" aria-labelledby="svgTitle" />
    </svg>
  </div>
</div>
