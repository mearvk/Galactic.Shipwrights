  <div class="carousel-section">
  <div class="carousel-section-header">
    <h2 class="home-h2">Welcome to Open Library</h2>
  </div>

  <div class="carousel-container">
    <div
      class="carousel carousel--progressively-enhanced"
      data-config="{&quot;carouselKey&quot;: &quot;welcome&quot;, &quot;booksPerBreakpoint&quot;: [3, 2, 2, 1, 1]}"
    >
      










<div class="carousel__item tutorial__item">
  <a
    href="/help/faq/borrow"
    tabindex="0"
    data-ol-link-track=&quot;OnboardingCarouselClick|Read&quot;
  >
    <img src="/static/images/onboarding/read.png"
      alt=""
      
      
    >
    <div class="card__text">
      <p>Read Free Library Books Online</p>
      <p class="small">Millions of books available through Controlled Digital Lending</p>
    </div>
  </a>
</div>


      










<div class="carousel__item tutorial__item">
  <a
    href="/help/faq/yearly-reading-goals"
    tabindex="0"
    data-ol-link-track=&quot;OnboardingCarouselClick|YearlyReadingGoals&quot;
  >
    <img src="/static/images/onboarding/reading_goal.svg"
      alt=""
      
      
      data-attribution="Calendar by Oksana Latysheva from the Noun Project"
    >
    <div class="card__text">
      <p>Set a Yearly Reading Goal</p>
      <p class="small">Learn how to set a yearly reading goal and track what you read</p>
    </div>
  </a>
</div>


      










<div class="carousel__item tutorial__item">
  <a
    href="/help/faq/reading-log"
    tabindex="0"
    data-ol-link-track=&quot;OnboardingCarouselClick|Organize&quot;
  >
    <img src="/static/images/onboarding/track.png"
      alt=""
      
      
    >
    <div class="card__text">
      <p>Keep Track of your Favorite Books</p>
      <p class="small">Organize your Books using Lists &amp; the Reading Log</p>
    </div>
  </a>
</div>


      










<div class="carousel__item tutorial__item">
  <a
    href="/explore"
    tabindex="0"
    data-ol-link-track=&quot;OnboardingCarouselClick|Explore&quot;
  >
    <img src="/static/images/onboarding/library_explorer.png"
      alt=""
      
      
    >
    <div class="card__text">
      <p>Try the virtual Library Explorer</p>
      <p class="small">Digital shelves organized like a physical library</p>
    </div>
  </a>
</div>


      










<div class="carousel__item tutorial__item">
  <a
    href="/search/inside"
    tabindex="0"
    data-ol-link-track=&quot;OnboardingCarouselClick|FulltextSearch&quot;
  >
    <img src="/static/images/onboarding/fulltext.png"
