<?xml version="1.0" encoding="UTF-8"?>
<config>
    <!-- Galactic Shipwrights - Central Configuration -->
    <!-- Max Rupplin - MEARVK LLC -->

    <guildServer>
        <port>10001</port>
        <redundancy>3</redundancy>
        <monitorInterval>5000</monitorInterval>
    </guildServer>

    <reacher>
        <sourcesPath>src/sources.xml</sourcesPath>
        <outputDir>src/edifiction</outputDir>
        <timeout>30000</timeout>
        <userAgent>GalacticShipwrights/1.0</userAgent>
        <respectRobotsTxt>true</respectRobotsTxt>
    </reacher>

    <dictionaryProfiler>
        <enabled>true</enabled>
        <outputFile>dictionaries/dictionary.list.txt</outputFile>
        <scanDirs>src/edifiction</scanDirs>
        <definitionSources>
            <source>https://en.wiktionary.org/w/api.php</source>
            <source>https://api.dictionaryapi.dev/api/v2/entries/en/</source>
        </definitionSources>
    </dictionaryProfiler>

    <speculatorTrainer>
        <modelDir>trainer</modelDir>
        <modelFile>trainer/speculator.model</modelFile>
        <corpusDir>src/edifiction</corpusDir>
        <databaseConfig>src/database.xml</databaseConfig>
    </speculatorTrainer>

    <speculator>
        <knownServersFile>configuration/known.port.20000.servers.xml</knownServersFile>
        <relayPort>20000</relayPort>
        <minInterestScore>0.7</minInterestScore>
    </speculator>

    <moduleInstallServer>
        <port>2000</port>
        <configFile>configuration/port.2000.config.xml</configFile>
        <knownServers49152>configuration/known.port.49152.servers.xml</knownServers49152>
        <modulesDir>modules</modulesDir>
    </moduleInstallServer>

    <jwstfj21Integration>
        <enabled>true</enabled>
        <configFile>configuration/jwstfj21-integration.xml</configFile>
        <mode>auto</mode> <!-- auto: attempt integration, fallback to standalone -->
    </jwstfj21Integration>
</config>
