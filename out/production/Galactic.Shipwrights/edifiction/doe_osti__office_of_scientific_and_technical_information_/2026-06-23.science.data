      "Pierce, Dean T [ORNL] (ORCID:0000000304223423)",
      "Lowe, Tracie [ORNL]",
      "Haynes, James A [ORNL] (ORCID:0000000242367383)"
    ],
    "doe_contract_number": "AC05-00OR22725; ",
